<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="swerve_wheels_and_magnets" params="">
        
        <link name="magnetic_plate_link">
            <visual>
                <geometry> <box size="0.25 0.18 0.01"/> </geometry>
                <material name="plate_blue">
                    <color rgba="0.16 0.45 0.95 1.0"/>
                </material>
            </visual>
            <collision>
                <geometry> <box size="0.25 0.18 0.01"/> </geometry>
            </collision>
            <inertial>
                <mass value="0.5"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>

        <joint name="magnetic_plate_joint" type="fixed">
            <parent link="chassis"/>
            <child link="magnetic_plate_link"/>
            <origin xyz="0 0 -0.035" rpy="0 0 0"/>
        </joint>


        <xacro:macro name="swerve_wheel" params="prefix x_pos y_pos">
            
            <joint name="${prefix}_steering_joint" type="revolute">
                <parent link="magnetic_plate_link"/>
                <child link="${prefix}_steering_housing"/>
                <origin xyz="${x_pos} ${y_pos} 0" rpy="0 0 0"/>
                <axis xyz="0 0 1"/>
                <limit lower="-3.14" upper="3.14" effort="200.0" velocity="100.0"/>
                <dynamics damping="0.02" friction="0.02"/>
            </joint>

            <link name="${prefix}_steering_housing">
                <visual>
                    <geometry> <cylinder radius="0.008" length="0.004"/> </geometry>
                    <material name="housing_grey">
                        <color rgba="0.30 0.34 0.40 1.0"/>
                    </material>
                </visual>
                <inertial>
                    <mass value="0.05"/>
                    <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
                </inertial>
            </link>

            <joint name="${prefix}_wheel_joint" type="continuous">
                <parent link="${prefix}_steering_housing"/>
                <child link="${prefix}_wheel_link"/>
                
                <origin xyz="0 0 0.001" rpy="0 0 0"/>
                
                <axis xyz="0 1 0"/>
                <limit effort="200.0" velocity="200.0"/>
                <dynamics damping="0.1" friction="0.1"/>
            </joint>

            <link name="${prefix}_wheel_link">
                <visual>
                    <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                    <geometry> <cylinder radius="0.008" length="0.005"/> </geometry>
                    <material name="wheel_black">
                        <color rgba="0.06 0.06 0.06 1.0"/>
                    </material>
                </visual>
                <collision>
                    <origin xyz="0 0 0" rpy="0 0 0"/>
                    <geometry> <sphere radius="0.008"/> </geometry>
                </collision>
                <inertial>
                    <mass value="0.05"/>
                    <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
                </inertial>
            </link>
        </xacro:macro>

        <xacro:swerve_wheel prefix="front_left"  x_pos="0.08"  y_pos="0.06"/>
        <xacro:swerve_wheel prefix="front_right" x_pos="0.08"  y_pos="-0.06"/>
        <xacro:swerve_wheel prefix="rear_left"   x_pos="-0.08" y_pos="0.06"/>
        <xacro:swerve_wheel prefix="rear_right"  x_pos="-0.08" y_pos="-0.06"/>

    </xacro:macro>
</robot>