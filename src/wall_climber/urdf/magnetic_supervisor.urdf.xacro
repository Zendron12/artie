<?xml version="1.0"?>
<!--
  Minimal URDF for the invisible Magnetic Supervisor robot.
  Its only purpose is to tell webots_ros2_driver which plugin to load.
  The actual Robot node lives in wall_world.wbt (supervisor TRUE).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="magnetic_supervisor">

  <link name="base_link"/>

  <webots>
    <plugin type="wall_climber.magnetic_supervisor_plugin.MagneticSupervisorPlugin">
      <target_robot>wall_climber</target_robot>
      <wall_y>2.415</wall_y>
      <activation_distance>0.8</activation_distance>
      <adhesion_force>55.0</adhesion_force>
      <robot_mass>2.5</robot_mass>
      <gravity>9.81</gravity>
      <anti_gravity_ratio>1.05</anti_gravity_ratio>
      <board_center_x>0.0</board_center_x>
      <board_center_z>1.8</board_center_z>
      <board_width>6.3</board_width>
      <board_height>2.8</board_height>
      <margin_left>0.10</margin_left>
      <margin_right>0.10</margin_right>
      <margin_top>0.10</margin_top>
      <margin_bottom>0.10</margin_bottom>
      <line_height>0.14</line_height>
      <trail_half_width>0.010</trail_half_width>
      <trail_round_segments>12</trail_round_segments>
    </plugin>
  </webots>

</robot>
