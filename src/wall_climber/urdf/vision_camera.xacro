<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="vision_camera">

  <xacro:property name="base_width" value="0.25"/>
  <xacro:property name="base_height" value="0.05"/>
  <xacro:property name="stand_radius" value="0.04"/>
  <xacro:property name="stand_height" value="1.70"/>
  <xacro:property name="body_width" value="0.12"/>
  <xacro:property name="body_length" value="0.15"/>
  <xacro:property name="body_height" value="0.08"/>
  <xacro:property name="camera_size" value="0.03"/>
  <xacro:property name="camera_offset_z" value="0.05"/>
  <xacro:property name="image_width" value="1920"/>
  <xacro:property name="image_height" value="1080"/>
  <xacro:property name="camera_fov" value="1.2"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_width} ${base_width} ${base_height}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_width} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height / 2}" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="stand_link">
    <visual>
      <origin xyz="0 0 ${stand_height / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${stand_radius}" length="${stand_height}"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${stand_height / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${stand_radius}" length="${stand_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${stand_height / 2}" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <link name="body_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_size} ${camera_size} ${camera_size}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.5 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_size} ${camera_size} ${camera_size}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <link name="camera_optical_frame"/>

  <joint name="base_to_stand" type="fixed">
    <parent link="base_link"/>
    <child link="stand_link"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <joint name="pan_joint" type="revolute">
    <parent link="stand_link"/>
    <child link="body_link"/>
    <origin xyz="0 0 ${stand_height + body_height / 2}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.5"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <joint name="body_to_camera" type="fixed">
    <parent link="body_link"/>
    <child link="camera_link"/>
    <origin xyz="${body_length / 2 + camera_size / 2} 0 ${camera_offset_z}" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <joint name="camera_to_optical" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <!--
    NOTE:
    This sensor block is used by the Webots URDF importer to generate a real
    Camera device in the spawned Webots robot. It is not a Gazebo runtime node.
  -->
  <gazebo reference="camera_link">
    <sensor name="camera_link" type="camera">
      <camera>
        <horizontal_fov>${camera_fov}</horizontal_fov>
        <image>
          <width>${image_width}</width>
          <height>${image_height}</height>
          <format>R8G8B8A8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <update_rate>15</update_rate>
    </sensor>
  </gazebo>
  
  <webots>
    <device reference="camera_link" type="Camera">
      <ros>
        <enabled>false</enabled>
      </ros>
    </device>
    <plugin type="wall_climber.camera_plugin.CameraPlugin">
      <camera_name>camera_link</camera_name>
      <frame_id>camera_optical_frame</frame_id>
      <fov>${camera_fov}</fov>
    </plugin>
  </webots>

</robot>