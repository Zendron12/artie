<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- ═══════════════════════════════════════════════════════════════
         5-Bar Pantograph Writing Arm  (scaled-up, industrial)
         ───────────────────────────────────────────────────────────────
         Mounted on the TOP EDGE of the orange chassis (y ≈ +0.11)
         on the wall-facing side (z ≈ −0.035).  This avoids collision
         with the belly plate and wheels below.

         Arms extend in URDF +Y  (= world +Z = UPWARD on the wall).
         The marker tip points in URDF −Z (= world +Y = toward wall).

         Coordinate mapping after spawn rotation (1 0 0 1.57):
           URDF +X → Wall right    URDF +Y → Wall up
           URDF −Z → Toward wall   URDF +Z → Away from wall

         pen_mount_joint is PRISMATIC along Z so the marker can be
         lifted off / pressed onto the whiteboard.

         URDF tree (open-chain approximation of closed 5-bar):
           Left  chain: chassis → shoulder → upper → elbow → forearm → pen
           Right chain: chassis → shoulder → upper → elbow → forearm
         ═══════════════════════════════════════════════════════════════ -->

    <xacro:macro name="pantograph_arm" params="">

        <!-- ── Geometry Parameters (scaled-up industrial) ──────── -->
        <xacro:property name="sh_half"       value="0.05"/>   <!-- half shoulder spacing   -->
        <xacro:property name="upper_len"     value="0.14"/>   <!-- upper arm length        -->
        <xacro:property name="fore_len"      value="0.18"/>   <!-- forearm length           -->
        <xacro:property name="bar_w"         value="0.022"/>  <!-- arm bar width            -->
        <xacro:property name="bar_t"         value="0.008"/>  <!-- arm bar thickness        -->
        <xacro:property name="jc_r"          value="0.014"/>  <!-- joint cover radius       -->
        <xacro:property name="jc_t"          value="0.010"/>  <!-- joint cover thickness    -->
        <xacro:property name="motor_r"       value="0.022"/>  <!-- motor housing radius     -->
        <xacro:property name="motor_h"       value="0.018"/>  <!-- motor housing height     -->
        <xacro:property name="marker_r"      value="0.012"/>  <!-- marker body radius       -->
        <xacro:property name="marker_h"      value="0.060"/>  <!-- marker body length       -->
        <xacro:property name="marker_tip_r"  value="0.006"/>  <!-- marker tip radius        -->
        <xacro:property name="marker_tip_h"  value="0.012"/>  <!-- marker tip length        -->
        <xacro:property name="marker_tip_contact_r" value="0.004"/> <!-- smooth contact sphere -->
        <xacro:property name="marker_tip_front_z" value="${-(marker_h + marker_tip_h + 0.002) + 0.03}"/>
        <xacro:property name="marker_tip_contact_z" value="${marker_tip_front_z + marker_tip_contact_r}"/>
        <xacro:property name="arm_y"         value="0.10"/>   <!-- Y offset on chassis (top edge) -->
        <xacro:property name="arm_z"         value="0"/> <!-- Z offset (wall-facing side) -->
        <!-- Forearm inward angle so tips converge at centre:
             asin(sh_half / fore_len) = asin(0.05/0.18) ≈ 0.281 rad -->
        <xacro:property name="fore_angle"    value="0.281"/>


        <!-- ═══════════ SHOULDER MOTOR HOUSINGS (fixed to chassis) ═ -->

        <!-- Left motor housing -->
        <link name="left_motor_housing">
            <visual>
                <geometry><cylinder radius="${motor_r}" length="${motor_h}"/></geometry>
                <material name="motor_dark"><color rgba="0.12 0.14 0.18 1.0"/></material>
            </visual>
            <!-- Accent ring -->
            <visual>
                <origin xyz="0 0 ${motor_h/2}"/>
                <geometry><cylinder radius="${motor_r + 0.003}" length="0.003"/></geometry>
                <material name="accent_ring"><color rgba="0.4 0.42 0.48 1.0"/></material>
            </visual>
            <inertial>
                <mass value="0.04"/>
                <inertia ixx="2e-6" ixy="0" ixz="0" iyy="2e-6" iyz="0" izz="2e-6"/>
            </inertial>
        </link>
        <joint name="left_motor_mount" type="fixed">
            <parent link="chassis"/>
            <child link="left_motor_housing"/>
            <origin xyz="${-sh_half} ${arm_y} ${arm_z}" rpy="0 0 0"/>
        </joint>

        <!-- Right motor housing -->
        <link name="right_motor_housing">
            <visual>
                <geometry><cylinder radius="${motor_r}" length="${motor_h}"/></geometry>
                <material name="motor_dark"><color rgba="0.12 0.14 0.18 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 0 ${motor_h/2}"/>
                <geometry><cylinder radius="${motor_r + 0.003}" length="0.003"/></geometry>
                <material name="accent_ring"><color rgba="0.4 0.42 0.48 1.0"/></material>
            </visual>
            <inertial>
                <mass value="0.04"/>
                <inertia ixx="2e-6" ixy="0" ixz="0" iyy="2e-6" iyz="0" izz="2e-6"/>
            </inertial>
        </link>
        <joint name="right_motor_mount" type="fixed">
            <parent link="chassis"/>
            <child link="right_motor_housing"/>
            <origin xyz="${sh_half} ${arm_y} ${arm_z}" rpy="0 0 0"/>
        </joint>


        <!-- ═══════════ LEFT CHAIN (primary — carries the marker) ══ -->

        <!-- Left shoulder actuator -->
        <joint name="left_shoulder_joint" type="revolute">
            <parent link="chassis"/>
            <child link="left_upper_arm"/>
            <origin xyz="${-sh_half} ${arm_y} ${arm_z}" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-2.35" upper="2.35" effort="50" velocity="6.0"/>
            <dynamics damping="0.08" friction="0.02"/>
        </joint>

        <link name="left_upper_arm">
            <!-- Joint cover at shoulder (zero-origin FIRST — urdf2webots bug) -->
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <!-- Arm bar (industrial silver, flat profile) -->
            <visual>
                <origin xyz="0 ${upper_len/2} 0"/>
                <geometry><box size="${bar_w} ${upper_len} ${bar_t}"/></geometry>
                <material name="arm_silver"><color rgba="0.78 0.80 0.84 1.0"/></material>
            </visual>
            <collision>
                <origin xyz="0 ${upper_len/2} 0"/>
                <geometry><box size="${bar_w} ${upper_len} ${bar_t}"/></geometry>
            </collision>
            <inertial>
                <origin xyz="0 ${upper_len/2} 0"/>
                <mass value="0.06"/>
                <inertia ixx="1.0e-4" ixy="0" ixz="0" iyy="1.5e-6" iyz="0" izz="1.0e-4"/>
            </inertial>
        </link>

        <!-- Left elbow (passive) -->
        <joint name="left_elbow_joint" type="revolute">
            <parent link="left_upper_arm"/>
            <child link="left_elbow_pivot"/>
            <origin xyz="0 ${upper_len} 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-2.35" upper="2.35" effort="10" velocity="6.0"/>
            <dynamics damping="0.05" friction="0.01"/>
        </joint>

        <link name="left_elbow_pivot">
            <!-- Elbow cover -->
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <inertial>
                <mass value="0.02"/>
                <inertia ixx="5e-7" ixy="0" ixz="0" iyy="5e-7" iyz="0" izz="5e-7"/>
            </inertial>
        </link>

        <!-- Fixed offset to angle the forearm inward -->
        <joint name="left_forearm_offset" type="fixed">
            <parent link="left_elbow_pivot"/>
            <child link="left_forearm"/>
            <origin xyz="0 0 0" rpy="0 0 ${-fore_angle}"/>
        </joint>

        <link name="left_forearm">
            <!-- Elbow cover (zero-origin FIRST — urdf2webots bug) -->
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <!-- Arm bar -->
            <visual>
                <origin xyz="0 ${fore_len/2} 0"/>
                <geometry><box size="${bar_w} ${fore_len} ${bar_t}"/></geometry>
                <material name="arm_silver"><color rgba="0.78 0.80 0.84 1.0"/></material>
            </visual>
            <!-- Tip-end cover -->
            <visual>
                <origin xyz="0 ${fore_len} 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <collision>
                <origin xyz="0 ${fore_len/2} 0"/>
                <geometry><box size="${bar_w} ${fore_len} ${bar_t}"/></geometry>
            </collision>
            <inertial>
                <origin xyz="0 ${fore_len/2} 0"/>
                <mass value="0.06"/>
                <inertia ixx="1.6e-4" ixy="0" ixz="0" iyy="1.5e-6" iyz="0" izz="1.6e-4"/>
            </inertial>
        </link>


        <!-- ── Marker Assembly (prismatic pen-lift at left forearm tip) ── -->

        <joint name="pen_mount_joint" type="prismatic">
            <parent link="left_forearm"/>
            <child link="pen_holder"/>
            <origin xyz="0 ${fore_len} 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-0.04" upper="0.02" effort="20" velocity="1.2"/>
            <dynamics damping="0.1" friction="0.05"/>
        </joint>

        <link name="pen_holder">
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${marker_r + 0.004}" length="0.008"/></geometry>
                <material name="grip_dark"><color rgba="0.18 0.20 0.24 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 0 ${-marker_h/2 + 0.03}"/>
                <geometry><cylinder radius="${marker_r}" length="${marker_h}"/></geometry>
                <material name="marker_red"><color rgba="0.90 0.10 0.10 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 0 ${-marker_h + 0.003 + 0.03}"/>
                <geometry><cylinder radius="${marker_r + 0.002}" length="0.006"/></geometry>
                <material name="cap_band"><color rgba="0.15 0.15 0.15 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 0 ${-(marker_h + marker_tip_h/2 + 0.002) + 0.03}"/>
                <geometry><cylinder radius="${marker_tip_r}" length="${marker_tip_h}"/></geometry>
                <material name="tip_dark"><color rgba="0.08 0.08 0.08 1.0"/></material>
            </visual>
            <!-- A small spherical contact tip gives smoother sliding on the board
                 while keeping the physical contact patch compact and low-catching. -->
            <collision>
                <origin xyz="0 0 ${marker_tip_contact_z}"/>
                <geometry><sphere radius="${marker_tip_contact_r}"/></geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 ${-marker_h/2 + 0.03}"/>
                <mass value="0.025"/>
                <inertia ixx="4e-6" ixy="0" ixz="0" iyy="4e-6" iyz="0" izz="2e-6"/>
            </inertial>
        </link>

        <!-- ═══════════ RIGHT CHAIN (passive / constrained) ════════ -->

        <!-- Right shoulder actuator -->
        <joint name="right_shoulder_joint" type="revolute">
            <parent link="chassis"/>
            <child link="right_upper_arm"/>
            <origin xyz="${sh_half} ${arm_y} ${arm_z}" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-2.35" upper="2.35" effort="50" velocity="6.0"/>
            <dynamics damping="0.08" friction="0.02"/>
        </joint>

        <link name="right_upper_arm">
            <!-- Joint cover (zero-origin FIRST — urdf2webots bug) -->
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 ${upper_len/2} 0"/>
                <geometry><box size="${bar_w} ${upper_len} ${bar_t}"/></geometry>
                <material name="arm_silver"><color rgba="0.78 0.80 0.84 1.0"/></material>
            </visual>
            <collision>
                <origin xyz="0 ${upper_len/2} 0"/>
                <geometry><box size="${bar_w} ${upper_len} ${bar_t}"/></geometry>
            </collision>
            <inertial>
                <origin xyz="0 ${upper_len/2} 0"/>
                <mass value="0.06"/>
                <inertia ixx="1.0e-4" ixy="0" ixz="0" iyy="1.5e-6" iyz="0" izz="1.0e-4"/>
            </inertial>
        </link>

        <!-- Right elbow (passive, mirrored) -->
        <joint name="right_elbow_joint" type="revolute">
            <parent link="right_upper_arm"/>
            <child link="right_elbow_pivot"/>
            <origin xyz="0 ${upper_len} 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-2.35" upper="2.35" effort="10" velocity="6.0"/>
            <dynamics damping="0.05" friction="0.01"/>
        </joint>

        <link name="right_elbow_pivot">
            <!-- Elbow cover -->
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <inertial>
                <mass value="0.02"/>
                <inertia ixx="5e-7" ixy="0" ixz="0" iyy="5e-7" iyz="0" izz="5e-7"/>
            </inertial>
        </link>

        <!-- Fixed offset to angle the forearm inward (mirrored) -->
        <joint name="right_forearm_offset" type="fixed">
            <parent link="right_elbow_pivot"/>
            <child link="right_forearm"/>
            <origin xyz="0 0 0" rpy="0 0 ${fore_angle}"/>
        </joint>

        <link name="right_forearm">
            <!-- Elbow cover (zero-origin FIRST — urdf2webots bug) -->
            <visual>
                <origin xyz="0 0 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 ${fore_len/2} 0"/>
                <geometry><box size="${bar_w} ${fore_len} ${bar_t}"/></geometry>
                <material name="arm_silver"><color rgba="0.78 0.80 0.84 1.0"/></material>
            </visual>
            <visual>
                <origin xyz="0 ${fore_len} 0"/>
                <geometry><cylinder radius="${jc_r}" length="${jc_t}"/></geometry>
                <material name="jc_grey"><color rgba="0.30 0.33 0.38 1.0"/></material>
            </visual>
            <collision>
                <origin xyz="0 ${fore_len/2} 0"/>
                <geometry><box size="${bar_w} ${fore_len} ${bar_t}"/></geometry>
            </collision>
            <inertial>
                <origin xyz="0 ${fore_len/2} 0"/>
                <mass value="0.06"/>
                <inertia ixx="1.6e-4" ixy="0" ixz="0" iyy="1.5e-6" iyz="0" izz="1.6e-4"/>
            </inertial>
        </link>

    </xacro:macro>
</robot>
